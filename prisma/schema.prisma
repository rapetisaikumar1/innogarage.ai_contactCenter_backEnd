// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  AGENT
  MANAGER
}

enum CandidateStatus {
  INITIAL_EVALUATION_DONE
  AWAITING_RESUME
  RESUME_SHARED
  MARKETING_STARTED
  CANDIDATE_GOT_OFFER
  BGC_ONGOING
  STARTED_WORKING
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageChannel {
  WHATSAPP
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  IN_CALL
  MISSED
  COMPLETED
}

enum VoiceSessionStatus {
  RINGING
  CLAIMED
  IN_CALL
  ENDED
}

enum VoicePresenceStatus {
  IDLE
  IN_CALL
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  OVERDUE
  RESCHEDULED
}

enum ConversationStatus {
  UNASSIGNED
  ASSIGNED
  CLOSED
}

enum AssignmentAction {
  ASSIGNED
  REASSIGNED
  UNASSIGNED
  CLOSED
  REOPENED
}

enum UserAvailability {
  AVAILABLE
  BUSY
  AWAY
  OFFLINE
}

enum TransferRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(AGENT)
  isActive     Boolean  @default(true)
  availability UserAvailability @default(AVAILABLE)
  voiceStatus  VoicePresenceStatus @default(IDLE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notes              Note[]
  followUps          FollowUp[]
  assignedCandidates CandidateAssignment[] @relation("AssignedToUser")
  assignedBy         CandidateAssignment[] @relation("AssignedByUser")
  sentMessages       Message[]
  statusChanges      StatusHistory[]
  auditLogs          AuditLog[]
  uploadedFiles      CandidateFile[]
  loggedCalls        Call[]
  claimedVoiceSessions VoiceSession[] @relation("ClaimedVoiceSessions")

  // WhatsApp conversation assignment
  assignedConversations    Conversation[]              @relation("AssignedConversations")
  notifications            Notification[]
  performedAssignments     ConversationAssignmentLog[] @relation("PerformedAssignments")
  previousAgentAssignments ConversationAssignmentLog[] @relation("PreviousAgentAssignments")
  newAgentAssignments      ConversationAssignmentLog[] @relation("NewAgentAssignments")

  // Transfer requests
  sentTransferRequests     CandidateTransferRequest[]  @relation("TransferFromAgent")
  receivedTransferRequests CandidateTransferRequest[]  @relation("TransferToAgent")

  // Agent notifications
  agentNotifications AgentNotification[]

  @@map("users")
}

model Candidate {
  id              String          @id @default(cuid())
  fullName        String
  phoneNumber     String
  whatsappNumber  String?
  email           String?
  city            String?
  qualification   String?
  skills          String?
  experience      String?
  preferredRole   String?
  status          CandidateStatus @default(INITIAL_EVALUATION_DONE)
  source          String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  assignments   CandidateAssignment[]
  messages      Message[]
  calls         Call[]
  notes         Note[]
  followUps     FollowUp[]
  statusHistory StatusHistory[]
  files         CandidateFile[]
  conversation  Conversation?
  transferRequests CandidateTransferRequest[]
  voiceSessions VoiceSession[]

  @@index([status])
  @@index([phoneNumber])
  @@index([createdAt])
  @@map("candidates")
}

model CandidateAssignment {
  id          String   @id @default(cuid())
  candidateId String
  userId      String
  assignedById String
  assignedAt  DateTime @default(now())

  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  user       User      @relation("AssignedToUser", fields: [userId], references: [id])
  assignedBy User      @relation("AssignedByUser", fields: [assignedById], references: [id])

  @@index([candidateId])
  @@index([userId])
  @@map("candidate_assignments")
}

model Message {
  id                String           @id @default(cuid())
  candidateId       String
  conversationId    String?
  direction         MessageDirection
  channel           MessageChannel   @default(WHATSAPP)
  messageText       String
  externalMessageId String?          @unique
  sentByUserId      String?
  createdAt         DateTime         @default(now())

  candidate    Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  sentBy       User?         @relation(fields: [sentByUserId], references: [id])

  @@index([candidateId, createdAt])
  @@index([conversationId, createdAt])
  @@index([direction])
  @@map("messages")
}

model Call {
  id             String        @id @default(cuid())
  candidateId    String
  loggedById     String?
  direction      CallDirection
  phoneNumber    String
  duration       Int?          // seconds
  status         CallStatus
  providerCallId String?       @unique
  notes          String?
  voiceSessionId String?       @unique
  createdAt      DateTime      @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  loggedBy  User?     @relation(fields: [loggedById], references: [id])
  voiceSession VoiceSession? @relation(fields: [voiceSessionId], references: [id])

  @@index([candidateId, createdAt])
  @@index([loggedById])
  @@map("calls")
}

model VoiceSession {
  id              String             @id @default(cuid())
  candidateId     String
  direction       CallDirection
  rootCallSid     String             @unique
  bridgedCallSid  String?            @unique
  fromNumber      String
  toNumber        String
  isUnknownCaller Boolean            @default(false)
  status          VoiceSessionStatus @default(RINGING)
  assignedAgentId String?
  claimedAt       DateTime?
  answeredAt      DateTime?
  endedAt         DateTime?
  rawEndReason    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  call           Call?
  assignedAgent  User?     @relation("ClaimedVoiceSessions", fields: [assignedAgentId], references: [id])

  @@index([status, assignedAgentId])
  @@index([candidateId, createdAt])
  @@index([assignedAgentId, status])
  @@map("voice_sessions")
}

model Note {
  id          String   @id @default(cuid())
  candidateId String
  userId      String
  content     String
  createdAt   DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([candidateId, createdAt])
  @@map("notes")
}

model FollowUp {
  id          String         @id @default(cuid())
  candidateId String
  userId      String
  dueAt       DateTime
  status      FollowUpStatus @default(PENDING)
  remarks     String?
  completedAt DateTime?
  createdAt   DateTime       @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, status, dueAt])
  @@index([candidateId])
  @@map("follow_ups")
}

model StatusHistory {
  id          String          @id @default(cuid())
  candidateId String
  oldStatus   CandidateStatus
  newStatus   CandidateStatus
  changedById String
  changedAt   DateTime        @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  changedBy User      @relation(fields: [changedById], references: [id])

  @@index([candidateId, changedAt])
  @@map("status_history")
}

model CandidateFile {
  id           String   @id @default(cuid())
  candidateId  String
  uploadedById String
  originalName String
  mimeType     String
  size         Int
  url          String
  publicId     String
  createdAt    DateTime @default(now())

  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  uploadedBy User      @relation(fields: [uploadedById], references: [id])

  @@map("candidate_files")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ─── WhatsApp Conversation Models ─────────────────────────────────────────────

model Conversation {
  id                     String             @id @default(cuid())
  candidateId            String             @unique
  whatsappPhone          String
  status                 ConversationStatus @default(UNASSIGNED)
  assignedAgentId        String?
  assignedAt             DateTime?
  lastMessageAt          DateTime           @default(now())
  lastNotifiedAt         DateTime?
  notificationCycleCount Int                @default(0)
  isHighPriority         Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  candidate      Candidate                   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  assignedAgent  User?                       @relation("AssignedConversations", fields: [assignedAgentId], references: [id])
  messages       Message[]
  notifications  Notification[]
  assignmentLogs ConversationAssignmentLog[]

  @@index([assignedAgentId, status])
  @@index([status, lastMessageAt])
  @@map("conversations")
}

model Notification {
  id             String    @id @default(cuid())
  userId         String
  conversationId String
  type           String
  title          String
  body           String
  isRead         Boolean   @default(false)
  createdAt      DateTime  @default(now())
  clearedAt      DateTime?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId, clearedAt, createdAt])
  @@index([conversationId])
  @@map("notifications")
}

model ConversationAssignmentLog {
  id                String           @id @default(cuid())
  conversationId    String
  action            AssignmentAction
  performedByUserId String
  previousAgentId   String?
  newAgentId        String?
  createdAt         DateTime         @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  performedBy    User         @relation("PerformedAssignments", fields: [performedByUserId], references: [id])
  previousAgent  User?        @relation("PreviousAgentAssignments", fields: [previousAgentId], references: [id])
  newAgent       User?        @relation("NewAgentAssignments", fields: [newAgentId], references: [id])

  @@index([conversationId, createdAt])
  @@map("conversation_assignment_logs")
}

// ─── Transfer Request Models ───────────────────────────────────────────────────

model CandidateTransferRequest {
  id          String                @id @default(cuid())
  candidateId String
  fromAgentId String
  toAgentId   String
  status      TransferRequestStatus @default(PENDING)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  fromAgent User      @relation("TransferFromAgent", fields: [fromAgentId], references: [id])
  toAgent   User      @relation("TransferToAgent",   fields: [toAgentId],   references: [id])

  @@index([candidateId, status])
  @@index([toAgentId, status])
  @@map("candidate_transfer_requests")
}

model AgentNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("agent_notifications")
}

