  "version": "1.0.0",
  "description": "Contact Center Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "prisma generate && ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && tsc",
